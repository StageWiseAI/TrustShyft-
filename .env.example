# TrustShyft - Phase 1 environment variables
# Copy to .env at the repo root (or to apps/api/.env and apps/web/.env) before running locally.
# NEVER commit real secrets. This file documents required keys only.

# ---- Shared ----
NODE_ENV=development

# ---- API (apps/api) ----
API_PORT=4000
API_HOST=0.0.0.0

# PostgreSQL connection string used by Drizzle ORM.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://trustshyft:trustshyft@localhost:5432/trustshyft

# Clerk (auth) - server-side keys. Placeholders for Phase 1 middleware.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWT_ISSUER=

# CORS origin allowed by the API
WEB_ORIGIN=http://localhost:5173

# ---- Web (apps/web) ----
VITE_API_BASE_URL=http://localhost:4000
VITE_CLERK_PUBLISHABLE_KEY=

# ---- Railway / deployment placeholders ----
# RAILWAY_STATIC_URL=
# RAILWAY_ENVIRONMENT=
